# ============================================================
# Talk & Earn — Environment Configuration
# ============================================================
# Copy this file to .env and fill in real values before running.

# --- DATABASE ---
# SQLite (default for local development):
DATABASE_URL=sqlite+aiosqlite:///./talk_earn.db
# MySQL (uncomment & fill in for production):
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/talk_earn_db

# --- JWT SECURITY ---
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- EMAIL OTP (SMTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password_here

# --- STRIPE ---
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx

# --- COIN RATES ---
TEXT_COINS_PER_MIN=1
AUDIO_COINS_PER_MIN=2
VIDEO_COINS_PER_MIN=5
